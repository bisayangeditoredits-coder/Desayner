# ============================================
# CRELDESK STUDIO — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# ── SUPABASE (Database + Auth) ──────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── CLOUDFLARE R2 (Media Storage) ───────────
# Get these from: https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-custom-domain-or-r2-public-url.com


# ── STRIPE (Payments) ───────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id

# ── UPSTASH REDIS (Cache + Rate Limiting) ────
# Get these from: https://console.upstash.com → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ── UNSPLASH (Stock Photos) ──────────────────
# Get these from: https://unsplash.com/developers → Your App → Keys
# Free: 50 req/hour | Production (free): 10,000 req/hour
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ── APP CONFIG ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── E2E TESTS (optional) ─────────────────────
# Used by Playwright for the authenticated login test (e2e/login.spec.js)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# ── RESEND (Transactional Email) ─────────────
# Get from: https://resend.com → API Keys
# Domain desayner.com must be verified in Resend dashboard
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@desayner.com

# ── MICROSOFT CLARITY ────────────────────────
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id
